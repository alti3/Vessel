{
  "Vessel": {
    "Host": {
      "ServiceName": "Vessel.Web"
    },
    "Diagnostics": {
      "OpenTelemetryEnabled": true,
      "OtlpEndpoint": null
    },
    "Database": {
      "Enabled": false,
      "ConnectionString": null,
      "TimeoutSeconds": 5
    },
    "Redis": {
      "Enabled": false,
      "ConnectionString": null,
      "TimeoutSeconds": 5
    },
    "Hangfire": {
      "Enabled": false,
      "StorageProvider": "PostgreSql",
      "ConnectionString": null,
      "TimeoutSeconds": 5
    },
    "ObjectStorage": {
      "Enabled": false,
      "Provider": "S3",
      "Endpoint": null,
      "BucketName": null,
      "Region": null,
      "ForcePathStyle": true,
      "TimeoutSeconds": 5
    },
    "SecurityHeaders": {
      "Enabled": true,
      "ContentSecurityPolicy": "default-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'"
    },
    "RateLimits": {
      "Auth": {
        "PermitLimit": 20,
        "WindowSeconds": 60
      },
      "Webhooks": {
        "PermitLimit": 120,
        "WindowSeconds": 60
      },
      "Api": {
        "PermitLimit": 600,
        "WindowSeconds": 60
      },
      "Terminal": {
        "PermitLimit": 60,
        "WindowSeconds": 60
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
