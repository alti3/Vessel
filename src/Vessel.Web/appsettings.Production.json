{
  "Vessel": {
    "Diagnostics": {
      "OpenTelemetryEnabled": true,
      "OtlpEndpoint": null
    },
    "SecurityHeaders": {
      "Enabled": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  }
}
