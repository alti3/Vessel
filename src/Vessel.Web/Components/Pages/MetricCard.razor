<article class="metric-card">
    <div class="metric-icon @Tone">
        <Icon Name="@IconName" />
    </div>
    <div>
        <span>@Label</span>
        <strong>@Value</strong>
    </div>
</article>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string Value { get; set; } = "0";
    [Parameter] public string IconName { get; set; } = "home";
    [Parameter] public string Tone { get; set; } = "neutral";
}
