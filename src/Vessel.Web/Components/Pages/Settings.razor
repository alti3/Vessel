@page "/settings"
@attribute [Authorize]
@inject ISettingsCatalogQuery SettingsQuery
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Settings | Vessel</PageTitle>
<PageHeader Kicker="System" Title="Settings"
            Description="Team and system settings are exposed through explicit application queries."/>

@if (Items.Count == 0)
{
    <EmptyState Title="No settings found"
                Description="Settings will appear here when public configuration screens are implemented."/>
}
else
{
    <div class="table-wrap">
        <table class="data-table">
            <thead>
            <tr>
                <th>Scope</th>
                <th>Key</th>
                <th>Resource</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Items)
            {
                <tr>
                    <td>@item.Scope</td>
                    <td>@item.Key</td>
                    <td>@(item.ResourceType ?? "global")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@code {
    private IReadOnlyList<SettingListItem> Items { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        Items = SettingsQuery.List((await AuthenticationStateProvider.GetAuthenticationStateAsync()).User.GetTeamId());
    }

}
