@page "/applications/{Id:guid}"
@attribute [Authorize]
@inject StartDeploymentService DeploymentStarter
@inject DeploymentQueryService DeploymentDetails
@inject IDeploymentCatalogQuery DeploymentCatalog
@inject ApplicationWebhookConfigurationService WebhookConfiguration
@inject DomainRoutingService DomainRouting
@inject ProxyConfigurationService ProxyConfiguration
@inject Vessel.Application.Resources.ResourceManagementService Resources
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<ApplicationDetails> Logger

<PageTitle>Application | Vessel</PageTitle>
<PageHeader Kicker="Application" Title="Application overview" Description="@($"Application {Id} deployment, domains, environment, and logs.")">
    <button class="button button-primary" type="button" disabled="@IsStarting" @onclick="StartDeploymentAsync">
        <Icon Name="rocket" CssClass="size-4" />@(IsStarting ? "Starting" : "Deploy")
    </button>
</PageHeader>

@if (!string.IsNullOrWhiteSpace(Message))
{
    <div class="notice notice-info">@Message</div>
}

<section class="dashboard-grid">
    <SettingsPanel Title="Deployment" Description="Status, latest commit, rollback target, and deployment settings.">
        <div class="signal-list">
            <div class="signal-row"><span>Status</span><StatusBadge Text="@LatestStatus" Tone="@DeploymentTone(Latest?.Status)" /></div>
            <div class="signal-row"><span>Latest commit</span><span>@(Latest?.CommitSha ?? "not recorded")</span></div>
            <div class="signal-row"><span>Auto deploy</span><StatusBadge Text="Off" Tone="warning" /></div>
        </div>
    </SettingsPanel>
    <SettingsPanel Title="Configuration" Description="Build pack, runtime, domains, ports, and secret references.">
        <div class="signal-list">
            @foreach (var domain in Domains)
            {
                <div class="signal-row">
                    <span>@domain.Host</span>
                    <StatusBadge Text="@(domain.TlsEnabled ? domain.CertificateStatus?.ToString() ?? "TLS pending" : "HTTP")" Tone="@(domain.TlsEnabled ? "success" : "warning")" />
                </div>
            }
            @if (Domains.Count == 0)
            {
                <div class="signal-row"><span>No domains configured</span><StatusBadge Text="Missing" Tone="warning" /></div>
            }
        </div>
        <form class="form-stack" @onsubmit="SaveDomainAsync" @onsubmit:preventDefault>
            <FormField Label="Domain" Name="domain" @bind-Value="DomainHost" Placeholder="app.example.com" />
            <label>
                Target port
                <input class="form-control" type="number" min="1" max="65535" @bind="DomainPort" />
            </label>
            <label><input type="checkbox" @bind="DomainTlsEnabled" /> TLS</label>
            <label><input type="checkbox" @bind="DomainCanonical" /> Canonical host</label>
            <label><input type="checkbox" @bind="DomainRedirect" /> Redirect to canonical host</label>
            <button class="button button-secondary" type="submit">Save route</button>
        </form>
        <button class="button button-secondary" type="button" @onclick="ApplyProxyAsync">Apply proxy routes</button>
    </SettingsPanel>
    <SettingsPanel Title="Git Webhooks" Description="Provider trigger secrets, branch discovery, and preview deployment settings.">
        <div class="signal-list">
            @foreach (var webhook in Webhooks)
            {
                <div class="signal-row">
                    <span>@webhook.Provider</span>
                    <StatusBadge Text="Configured" Tone="success" />
                </div>
            }
            @if (Webhooks.Count == 0)
            {
                <div class="signal-row"><span>No provider webhooks configured</span><StatusBadge Text="Missing" Tone="warning" /></div>
            }
        </div>
        <form class="form-stack" @onsubmit="SaveWebhookAsync" @onsubmit:preventDefault>
            <label>
                Provider
                <select class="form-control" @bind="WebhookProviderValue">
                    <option value="GitHub">GitHub</option>
                    <option value="GitLab">GitLab</option>
                    <option value="Gitea">Gitea</option>
                    <option value="Bitbucket">Bitbucket</option>
                    <option value="Generic">Generic</option>
                </select>
            </label>
            <label>Secret<SecretInput Name="webhook-secret" @bind-Value="WebhookSecret" Placeholder="Webhook secret" /></label>
            <button class="button button-secondary" type="submit">Save webhook</button>
        </form>
    </SettingsPanel>
</section>

@if (Latest is not null)
{
    <section class="section-stack">
        <PageHeader Kicker="Latest deployment" Title="Logs" Description="Persisted deployment output. Live streaming is available to clients joined to the deployment SignalR group." />
        <div class="log-panel">
            @foreach (var line in Latest.Logs)
            {
                <div class="log-line log-@line.Stream"><span>@line.Sequence.ToString("0000")</span><code>@line.Message</code></div>
            }
        </div>
    </section>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Vessel.Application.Deployments.DeploymentDetails? Latest { get; set; }
    private bool IsStarting { get; set; }
    private string? Message { get; set; }
    private const string GenericErrorMessage = "An unexpected error occurred; please try again or contact support.";
    private System.Security.Claims.ClaimsPrincipal? User { get; set; }
    private IReadOnlyList<ApplicationWebhookConfigurationSummary> Webhooks { get; set; } = [];
    private IReadOnlyList<DomainRouteSummary> Domains { get; set; } = [];
    private Guid? ServerId { get; set; }
    private string WebhookProviderValue { get; set; } = WebhookProvider.GitHub.ToString();
    private string WebhookSecret { get; set; } = string.Empty;
    private string DomainHost { get; set; } = string.Empty;
    private int? DomainPort { get; set; } = 8080;
    private bool DomainTlsEnabled { get; set; } = true;
    private bool DomainCanonical { get; set; } = true;
    private bool DomainRedirect { get; set; }

    private string LatestStatus => Latest?.Status.ToString() ?? "Unknown";

    protected override async Task OnInitializedAsync()
    {
        User = (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;
        LoadLatest();
        LoadWebhooks();
        LoadDomains();
        LoadApplication();
    }

    private async Task StartDeploymentAsync()
    {
        if (User is null) return;
        IsStarting = true;
        Message = null;
        try
        {
            StartDeploymentResult result = await DeploymentStarter.StartAsync(
                User.GetUserId(),
                User.GetTeamId(),
                new StartDeploymentRequest(Id));
            Message = result.Message;
            Latest = DeploymentDetails.Get(User.GetUserId(), User.GetTeamId(), new DeploymentId(result.DeploymentId));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to start deployment for application {ApplicationId}.", Id);
            Message = GenericErrorMessage;
        }
        finally
        {
            IsStarting = false;
        }
    }

    private void LoadLatest()
    {
        if (User is null) return;
        DeploymentListItem? latest = DeploymentCatalog.List(User.GetTeamId())
            .Where(item => item.ApplicationId == Id)
            .OrderByDescending(item => item.CreatedAt)
            .FirstOrDefault();
        if (latest is not null)
            Latest = DeploymentDetails.Get(User.GetUserId(), User.GetTeamId(), new DeploymentId(latest.Id));
    }

    private void LoadWebhooks()
    {
        if (User is null) return;
        Webhooks = WebhookConfiguration.List(User.GetUserId(), User.GetTeamId(), new Vessel.Domain.ApplicationId(Id));
    }

    private void LoadDomains()
    {
        if (User is null) return;
        Domains = DomainRouting.List(User.GetUserId(), User.GetTeamId(), new Vessel.Domain.ApplicationId(Id));
    }

    private void LoadApplication()
    {
        if (User is null) return;
        ServerId = Resources.ListApplications(User.GetUserId(), User.GetTeamId())
            .SingleOrDefault(application => application.Id == Id)?.ServerId;
    }

    private async Task SaveDomainAsync()
    {
        if (User is null) return;
        try
        {
            await DomainRouting.ConfigureAsync(
                User.GetUserId(),
                User.GetTeamId(),
                new Vessel.Domain.ApplicationId(Id),
                new ConfigureDomainRouteRequest(DomainHost, DomainPort, DomainTlsEnabled, DomainCanonical, DomainRedirect));
            DomainHost = string.Empty;
            LoadDomains();
            Message = "Domain route saved.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save domain route for application {ApplicationId}.", Id);
            Message = GenericErrorMessage;
        }
    }

    private async Task ApplyProxyAsync()
    {
        if (User is null) return;
        try
        {
            if (ServerId is null)
            {
                Message = "Application server was not found.";
                return;
            }

            await ProxyConfiguration.GenerateValidateAndApplyAsync(User.GetUserId(), User.GetTeamId(), new ServerId(ServerId.Value));
            Message = "Proxy routes applied.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to apply proxy routes for application {ApplicationId}.", Id);
            Message = GenericErrorMessage;
        }
    }

    private async Task SaveWebhookAsync()
    {
        if (User is null) return;
        if (!Enum.TryParse(WebhookProviderValue, out WebhookProvider provider)) return;
        try
        {
            await WebhookConfiguration.ConfigureAsync(
                User.GetUserId(),
                User.GetTeamId(),
                new Vessel.Domain.ApplicationId(Id),
                new ConfigureApplicationWebhookRequest(provider, WebhookSecret));
            WebhookSecret = string.Empty;
            LoadWebhooks();
            Message = "Webhook configuration saved.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save webhook configuration for application {ApplicationId}.", Id);
            Message = GenericErrorMessage;
        }
    }

    private static string DeploymentTone(DeploymentStatus? status)
    {
        return status switch
        {
            DeploymentStatus.Succeeded => "success",
            DeploymentStatus.Failed => "danger",
            DeploymentStatus.CanceledByUser => "warning",
            DeploymentStatus.CancelRequested => "warning",
            DeploymentStatus.InProgress => "info",
            _ => "neutral"
        };
    }
}
