@page "/password-reset"
@attribute [AllowAnonymous]
@layout AuthLayout

<PageTitle>Password reset | Vessel</PageTitle>

<div class="auth-shell">
    <section class="auth-panel">
        <div class="brand brand-auth">
            <span class="brand-mark">V</span>
            <div><strong>Vessel</strong><span>Account recovery</span></div>
        </div>
        <h1>Reset password</h1>
        <p>Enter your email address. Vessel accepts the request without exposing whether the account exists.</p>
        <form class="form-stack" method="post" action="/api/auth/password-reset/request">
            <label>Email<input name="Email" type="email" autocomplete="email" required /></label>
            <button class="button button-primary button-full" type="submit">Request reset</button>
        </form>
        <div class="auth-links"><a href="/login">Back to login</a></div>
    </section>
</div>
