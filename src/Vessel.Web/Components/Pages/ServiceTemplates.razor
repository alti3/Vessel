@page "/service-templates"
@attribute [Authorize]
@inject ManagedDatabaseService ManagedServices
@inject ResourceManagementService Resources
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Service templates | Vessel</PageTitle>
<PageHeader Kicker="Managed services" Title="Service templates"
            Description="Create validated services from curated compose templates."/>

<section class="resource-grid">
    @foreach (var template in Templates)
    {
        <ResourceCard Title="@template.Name" Description="@template.Description" Href="#">
            <div class="signal-list">
                <div class="signal-row"><span>Template</span><strong>@template.Key</strong></div>
                <div class="signal-row"><span>Version</span><strong>@template.Version</strong></div>
            </div>
            <button class="button button-primary" type="button" @onclick="() => Select(template)">Select</button>
        </ResourceCard>
    }
</section>

@if (Selected is not null)
{
    <SettingsPanel Title="@($"Create {Selected.Name}")"
                   Description="Inputs marked as secret are redacted before persistence and logs.">
        <EditForm Model="Model" OnValidSubmit="CreateAsync" FormName="create-service-template">
            <div class="form-grid">
                <label>Name
                    <InputText @bind-Value="Model.Name" name="name"/>
                </label>
                <label>Project<select @bind="Model.ProjectId" name="project">@foreach (var project in Projects)
                        {
                            <option value="@project.Id">@project.Name</option>
                        }</select></label>
                <label>Environment<select @bind="Model.EnvironmentId"
                                          name="environment">@foreach (var environment in Environments)
                        {
                            <option value="@environment.Id">@environment.Name</option>
                        }</select></label>
                <label>Server<select @bind="Model.ServerId" name="server">@foreach (var server in Servers)
                        {
                            <option value="@server.Id">@server.Name</option>
                        }</select></label>
                @foreach (var input in Selected.Inputs)
                {
                    <label>@input.Label
                        <InputText Value="@GetInput(input.Key)"
                                   ValueChanged="value => SetInput(input.Key, value)"
                                   ValueExpression="() => Model.InputValue"
                                   name="@input.Key"/>
                    </label>
                }
                <button class="button button-primary" type="submit">Create service</button>
            </div>
        </EditForm>
    </SettingsPanel>
}

@code {
    private IReadOnlyList<ServiceTemplateSummary> Templates { get; set; } = [];
    private ServiceTemplateSummary? Selected { get; set; }
    private ServiceForm Model { get; } = new();
    private IReadOnlyList<ProjectSummary> Projects { get; set; } = [];
    private IReadOnlyList<EnvironmentSummary> Environments { get; set; } = [];
    private IReadOnlyList<ServerSummary> Servers { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        Templates = ManagedServices.ListTemplates();
        var user = (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;
        Projects = Resources.ListProjects(user.GetUserId(), user.GetTeamId()).Where(project => !project.IsArchived).ToArray();
        Servers = Resources.ListServers(user.GetUserId(), user.GetTeamId());
        if (Projects.Count > 0)
        {
            Model.ProjectId = Projects[0].Id;
            Environments = Resources.ListEnvironments(user.GetUserId(), user.GetTeamId(), new ProjectId(Model.ProjectId));
            Model.EnvironmentId = Environments.FirstOrDefault()?.Id ?? Guid.Empty;
        }

        Model.ServerId = Servers.FirstOrDefault()?.Id ?? Guid.Empty;
    }

    private void Select(ServiceTemplateSummary template)
    {
        Selected = template;
        Model.Name = template.Key;
        Model.Inputs.Clear();
        foreach (var input in template.Inputs.Where(input => input.DefaultValue is not null))
            Model.Inputs[input.Key] = input.DefaultValue!;
    }

    private string GetInput(string key)
    {
        return Model.Inputs.TryGetValue(key, out var value) ? value : string.Empty;
    }

    private void SetInput(string key, string value)
    {
        Model.Inputs[key] = value;
        Model.InputValue = value;
    }

    private async Task CreateAsync()
    {
        if (Selected is null) return;
        var user = (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;
        var service = await ManagedServices.CreateServiceFromTemplateAsync(user.GetUserId(), user.GetTeamId(),
            new CreateServiceFromTemplateRequest(Model.ProjectId, Model.EnvironmentId, Model.ServerId, Model.Name,
                Selected.Key, Model.Inputs));
        Navigation.NavigateTo($"/service-templates?created={service.Id}");
    }

    private sealed class ServiceForm
    {
        public Guid ProjectId { get; set; }
        public Guid EnvironmentId { get; set; }
        public Guid ServerId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string InputValue { get; set; } = string.Empty;
        public Dictionary<string, string> Inputs { get; } = [];
    }

}
