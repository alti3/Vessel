@page "/servers"
@attribute [Authorize]
@inject IServerCatalogQuery ServerQuery
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Servers | Vessel</PageTitle>
<PageHeader Kicker="Infrastructure" Title="Servers" Description="Hosts registered for external Docker or future Podman-compatible runtimes.">
    <a class="button button-primary" href="/servers/new"><Icon Name="plus" CssClass="size-4" />Add server</a>
</PageHeader>

@if (Items.Count == 0)
{
    <EmptyState Title="No servers found" Description="Add a server after configuring the credentials that Vessel will use to inspect and deploy to the host." ActionHref="/servers/new" ActionText="Add server" />
}
else
{
    <div class="table-wrap">
        <table class="data-table">
            <thead><tr><th>Name</th><th>Address</th><th>Runtime</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var item in Items)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Address</td>
                        <td>@item.Runtime</td>
                        <td><StatusBadge Text="@item.Status.ToString()" Tone="@ServerTone(item.Status)" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private IReadOnlyList<ServerListItem> Items { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        Items = ServerQuery.List((await AuthenticationStateProvider.GetAuthenticationStateAsync()).User.GetTeamId());
    }

    private static string ServerTone(ServerStatus status)
    {
        return status switch
        {
            ServerStatus.Reachable => "success",
            ServerStatus.Unreachable => "danger",
            ServerStatus.Draining or ServerStatus.PendingValidation => "warning",
            _ => "neutral"
        };
    }
}
