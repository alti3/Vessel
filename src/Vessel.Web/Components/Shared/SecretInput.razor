<div class="secret-input">
    <input id="@Id" name="@Name" type="@(Visible ? "text" : "password")" value="@Value" @oninput="OnInput" autocomplete="off" placeholder="@Placeholder" />
    <button class="icon-button" type="button" @onclick="Toggle" aria-label="Toggle secret visibility">
        <Icon Name="shield" CssClass="size-4" />
    </button>
</div>

@code {
    [Parameter] public string Id { get; set; } = $"secret-{Guid.NewGuid():N}";
    [Parameter] public string Name { get; set; } = "secret";
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Masked secret";

    private bool Visible { get; set; }

    private void Toggle()
    {
        Visible = !Visible;
    }

    private async Task OnInput(ChangeEventArgs args)
    {
        Value = args.Value?.ToString();
        await ValueChanged.InvokeAsync(Value);
    }
}
