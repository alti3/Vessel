<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <RedirectToLogin/>
                </NotAuthorized>
                <Authorizing>
                    <div class="auth-shell">
                        <div class="auth-panel">Checking session...</div>
                    </div>
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1"/>
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(MainLayout)">
                <EmptyState Title="Page not found" Description="The requested Vessel screen does not exist."
                            ActionHref="/" ActionText="Open dashboard"/>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
